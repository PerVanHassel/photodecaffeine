# Copy to .env and fill in. See README.md for where each value comes from.

PORT=8787

# --- Anthropic ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# --- Supabase (use a NEW, dedicated project -- not the PDC Studio one) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Twilio WhatsApp Sandbox ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Local dev only ---
# Set to true ONLY when testing locally without a real public HTTPS URL
# (e.g. hitting the webhook with curl directly). Never set this in staging/prod.
SKIP_TWILIO_SIGNATURE_CHECK=false
# Once you have an ngrok/tunnel URL, set the full webhook URL here so
# signature verification matches exactly what Twilio signed.
PUBLIC_WEBHOOK_URL=
